# GitLab MCP OpenAPI Configuration

# Required: GitLab Personal Access Token
# Create one at: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: api, read_user
GITLAB_TOKEN=

# Optional: GitLab API URL (defaults to gitlab.com)
GITLAB_API_URL=https://gitlab.labby.space

# Optional: Request timeout in milliseconds (default: 30000)
GITLAB_TIMEOUT=30000

# Optional: Enable OAuth mode (requires OAuth configuration)
# OAUTH_ENABLED=true
# GITLAB_OAUTH_CLIENT_ID=
# GITLAB_OAUTH_CLIENT_SECRET=
# OAUTH_SESSION_SECRET=